{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "hunt_package",
  "type": "object",
  "required": [
    "hunt_name",
    "hypothesis",
    "data_sources",
    "queries"
  ],
  "properties": {
    "hunt_name": {
      "type": "string"
    },
    "hypothesis": {
      "type": "string"
    },
    "data_sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "queries": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}